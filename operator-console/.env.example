# ============================================================
# 前端环境变量示例 (Frontend .env.example)
# 放置:operator-console/.env.example
#
# 用法 / Usage:
#   1. 本地开发复制为 .env.local 或 .env.development
#        cp .env.example .env.local
#   2. Vite 仅暴露以 VITE_ 开头的变量到客户端代码 (import.meta.env)
#   3. 切勿写入任何后端密钥 (Do NOT put secrets here — 会被打包进前端!)
#
# 变量名来自前端真实源码的 import.meta.env 调用:
#   src/services/WebSocketClient.js  -> VITE_WS_URL
#   src/services/authApi.js          -> VITE_AUTH_API_URL
#   src/utils/statsApi.js            -> VITE_STATS_API_URL
# ============================================================

# 交易服务 WebSocket 地址 (WebSocketClient.js)
# 不设置时回退默认: ws://localhost:8002
# 本地经 vite 代理可写: ws://127.0.0.1:8002  (vite.config.js 已代理 /ws -> 8002)
VITE_WS_URL=ws://localhost:8002

# 认证 API 基础地址 (authApi.js)
# 不设置时回退默认: http://localhost:8080/api/auth
VITE_AUTH_API_URL=http://localhost:8080/api/auth

# 统计 API 基础地址 (statsApi.js)
# 不设置时回退默认: /stats-api  (由 vite 代理到 http://127.0.0.1:8003)
# 如需直连可写完整地址: http://localhost:8003
VITE_STATS_API_URL=/stats-api

# 只读演示模式开关 (stores/user.js)
# true = 无后端时允许以「受限只读角色」登录预览界面（不连后端也能看 UI）。
# 默认 false。生产环境务必保持关闭，绝不要在真实部署里开启！
VITE_DEMO_MODE=false
