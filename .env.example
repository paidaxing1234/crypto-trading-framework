# ============================================================
# 后端环境变量示例 (Backend .env.example)
# 放置:仓库根目录 (_ctf_audit/.env.example)
#
# 用法 / Usage:
#   1. 复制为 .env:        cp .env.example .env
#   2. 填入真实值后再启动服务
#   3. 切勿提交 .env 到版本库 (Do NOT commit your real .env!)
#
# 变量名全部来自真实源码的 getenv / os.getenv / os.environ 调用:
#   cpp/server/config/server_config.cpp、cpp/core/config_center.h、
#   cpp/server/trading_server_main.cpp、cpp/network/proxy_config.h、
#   cpp/scripts/*.py、cpp/trading/alerts/*.py
# ============================================================

# ------------------------------------------------------------
# OKX 交易所 API (OKX exchange credentials)
# server_config.cpp / config_center.h / config_loader.h
# ------------------------------------------------------------
OKX_API_KEY=YOUR_OKX_API_KEY                # OKX API Key
OKX_SECRET_KEY=YOUR_OKX_SECRET_KEY          # OKX Secret Key
OKX_PASSPHRASE=YOUR_OKX_PASSPHRASE          # OKX API 密码短语 / passphrase
OKX_TESTNET=0                               # 1=测试网, 0=主网 (testnet flag)
OKX_PROXY_HOST=127.0.0.1                    # OKX 专用代理 host (config_center.h)
OKX_PROXY_PORT=7890                         # OKX 专用代理 port

# ------------------------------------------------------------
# Binance 交易所 API (Binance exchange credentials)
# server_config.cpp / config_center.h
# ------------------------------------------------------------
BINANCE_API_KEY=                            # Binance API Key (留空则仅拉公开行情)
BINANCE_SECRET_KEY=                         # Binance Secret Key
BINANCE_TESTNET=0                           # 1=测试网, 0=主网
BINANCE_PROXY_HOST=127.0.0.1                # Binance 专用代理 host
BINANCE_PROXY_PORT=7890                     # Binance 专用代理 port

# 通用回填脚本测试网开关 (kline_gap_filler.cpp)
TESTNET=0                                   # 1=测试网, 0=主网

# ------------------------------------------------------------
# Redis (缓存/行情/权益/统计) — 被 C++ 服务与所有 Python 脚本共用
# server_config / config_center / trading_server_main / py_strategy_base
# scripts(stats_api, equity_*, preload_*, fast_kline_filler ...)
# ------------------------------------------------------------
REDIS_HOST=127.0.0.1                        # Redis 主机 (host)
REDIS_PORT=6379                             # Redis 端口 (port)
REDIS_PASSWORD=                             # Redis 密码 (空=无密码 / leave empty if none)
REDIS_DB=0                                  # Redis 逻辑库编号 (db index)
REDIS_ENABLED=1                             # 1=启用 Redis 持久化, 0=关闭

# ------------------------------------------------------------
# 服务端口 (Service ports) — config_center.h
# ------------------------------------------------------------
WEBSOCKET_PORT=8002                         # 前端 WebSocket 服务端口
ZMQ_PUB_PORT=                               # ZMQ 发布端口 (PUB)
ZMQ_PULL_PORT=                              # ZMQ 拉取端口 (PULL)
ZMQ_REP_PORT=                               # ZMQ 应答端口 (REP)

# ------------------------------------------------------------
# 日志 (Logging) — config_center.h
# ------------------------------------------------------------
LOG_LEVEL=info                              # 日志级别 (debug/info/warn/error)
LOG_DIR=./logs                              # 日志目录

# ------------------------------------------------------------
# 统计 API 服务 (stats_api.py)
# ------------------------------------------------------------
STATS_API_HOST=127.0.0.1                    # stats_api 监听地址
STATS_API_PORT=8003                         # stats_api 监听端口

# ------------------------------------------------------------
# 出口代理 (Python 脚本通用代理) — fast_kline_filler / preload_*
# ------------------------------------------------------------
USE_PROXY=0                                 # 1/true/yes/on=走代理, 0=直连
PROXY_HOST=127.0.0.1                        # 代理 host
PROXY_PORT=7890                             # 代理 port
# 标准代理变量也被 C++ 读取 (proxy_config.h),按需设置其一即可:
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890

# ------------------------------------------------------------
# 邮件告警 (Email alerts) — cpp/trading/alerts/email_alert.py
# 全部为可选,按所用渠道填写
# ------------------------------------------------------------
EMAIL_ALERT_PROVIDER=smtp                   # 告警渠道: smtp / sendgrid / mailgun
SMTP_HOST=                                  # SMTP 服务器地址
SMTP_PORT=465                               # SMTP 端口 (465=SSL, 587=TLS)
SMTP_USER=                                  # SMTP 登录用户/发件邮箱
SMTP_PASSWORD=                              # SMTP 密码/授权码 (敏感)
EMAIL_FROM=                                 # 发件人邮箱
EMAIL_TO=                                   # 收件人邮箱, 多个用逗号分隔
SENDGRID_API_KEY=                           # SendGrid API Key (用 sendgrid 渠道时)
MAILGUN_API_KEY=                            # Mailgun API Key (用 mailgun 渠道时)
MAILGUN_DOMAIN=                             # Mailgun 域名

# ------------------------------------------------------------
# 飞书/Lark 告警 (Lark alerts) — cpp/trading/alerts/lark_alert.py
# 全部为可选
# ------------------------------------------------------------
LARK_WEBHOOK_URL=                           # 飞书自定义机器人 webhook URL
LARK_SECRET=                                # webhook 签名密钥 (敏感)
LARK_APP_ID=                                # 飞书应用 App ID (走应用消息时)
LARK_APP_SECRET=                            # 飞书应用 App Secret (敏感)
LARK_NOTIFY_EMAILS=                         # 接收通知的用户邮箱, 逗号分隔
LARK_DOMAIN=                                # 飞书域名 (国内 feishu / 海外 lark)

# ============================================================
# 安全提示 (Security note):
#   源码中【没有】从环境变量读取 JWT_SECRET / ADMIN_PASSWORD。
#   - JWT 密钥默认硬编码为 "CHANGE_ME_SET_A_STRONG_JWT_SECRET"
#       (cpp/network/auth_manager.h:70)
#   - 管理员默认口令硬编码为 "CHANGE_ME_ON_FIRST_LOGIN"
#       (cpp/network/auth_manager.h:95)
#   上线前【务必】在代码层改成从安全来源注入,并立即修改默认口令。
#   切勿把任何含真实密钥的 .env 提交到仓库。
# ============================================================
